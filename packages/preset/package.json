{
  "name": "@fetch-lite/preset",
  "type": "module",
  "version": "0.0.0",
  "description": "fetch-lite preset module",
  "author": "luvletterldl",
  "homepage": "https://github.com/luvletterldl/fetch-lite#readme",
  "repository": {
