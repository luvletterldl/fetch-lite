{
  "name": "@fetch-lite/base",
  "type": "module",
  "version": "0.0.0",
  "description": "fetch-lite base module",
  "author": "luvletterldl",
  "homepage": "https://github.com/luvletterldl/fetch-lite#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luvletterldl/fetch-lite.git",
    "directory": "packages/base"
  },
